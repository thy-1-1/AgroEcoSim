    output:
        "results/tables/stability_indicators.csv"
    shell:
        "echo 'This portfolio workflow documents the indicator-processing stage.' > {output}"

rule scenario_summary:
    output:
        "results/tables/scenario_summary.csv"
    shell:
        "echo 'This portfolio workflow documents the scenario-analysis stage.' > {output}"
